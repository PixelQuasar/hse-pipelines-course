          "refId": "A",
          "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse-main"},
          "editorType": "sql",
          "rawSql": "SELECT round(avg(n), 1) AS avg, quantile(0.5)(n) AS p50, quantile(0.9)(n) AS p90, quantile(0.99)(n) AS p99 FROM (SELECT session_id, count() AS n FROM bronze.events FINAL WHERE event_time >= now() - INTERVAL 24 HOUR GROUP BY session_id)",
