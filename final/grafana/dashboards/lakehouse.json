        {
          "refId": "A",
          "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse-main"},
          "editorType": "sql",
          "rawSql": "SELECT CASE toDayOfWeek(event_time) WHEN 1 THEN 'Пн' WHEN 2 THEN 'Вт' WHEN 3 THEN 'Ср' WHEN 4 THEN 'Чт' WHEN 5 THEN 'Пт' WHEN 6 THEN 'Сб' ELSE 'Вс' END AS day, countIf(toHour(event_time)=0) AS \"00\", countIf(toHour(event_time)=1) AS \"01\", countIf(toHour(event_time)=2) AS \"02\", countIf(toHour(event_time)=3) AS \"03\", countIf(toHour(event_time)=4) AS \"04\", countIf(toHour(event_time)=5) AS \"05\", countIf(toHour(event_time)=6) AS \"06\", countIf(toHour(event_time)=7) AS \"07\", countIf(toHour(event_time)=8) AS \"08\", countIf(toHour(event_time)=9) AS \"09\", countIf(toHour(event_time)=10) AS \"10\", countIf(toHour(event_time)=11) AS \"11\", countIf(toHour(event_time)=12) AS \"12\", countIf(toHour(event_time)=13) AS \"13\", countIf(toHour(event_time)=14) AS \"14\", countIf(toHour(event_time)=15) AS \"15\", countIf(toHour(event_time)=16) AS \"16\", countIf(toHour(event_time)=17) AS \"17\", countIf(toHour(event_time)=18) AS \"18\", countIf(toHour(event_time)=19) AS \"19\", countIf(toHour(event_time)=20) AS \"20\", countIf(toHour(event_time)=21) AS \"21\", countIf(toHour(event_time)=22) AS \"22\", countIf(toHour(event_time)=23) AS \"23\" FROM bronze.events FINAL WHERE event_type='SESSION_START' AND event_time >= now() - INTERVAL 7 DAY GROUP BY toDayOfWeek(event_time) ORDER BY toDayOfWeek(event_time)",
          "format": 1,
          "queryType": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "cellOptions": {"type": "color-background", "mode": "gradient"},
            "align": "center",
            "filterable": false
          },
          "color": {"mode": "continuous-YlOrRd"},
          "min": 0
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "day"},
            "properties": [
              {"id": "custom.cellOptions", "value": {"type": "auto"}},
              {"id": "custom.width", "value": 50},
              {"id": "custom.align", "value": "left"}
            ]
