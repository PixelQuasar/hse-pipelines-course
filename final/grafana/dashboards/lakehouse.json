          "rawSql": "SELECT toStartOfHour(event_time) AS t, toString(toDayOfWeek(event_time)) AS dow, count() AS events FROM bronze.events FINAL WHERE event_type='SESSION_START' AND event_time >= now() - INTERVAL 7 DAY GROUP BY t, dow ORDER BY t, dow",
