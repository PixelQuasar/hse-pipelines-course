    {
      "id": 11,
      "type": "table",
      "title": "Активность: час × день недели (последние 7 дней)",
      "gridPos": {"x": 0, "y": 45, "w": 24, "h": 8},
      "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse-main"},
